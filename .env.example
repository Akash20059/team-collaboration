# ─── Frontend (Vite / Netlify) ──────────────────────────────────────────────
# Your Supabase project public keys (safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# URL of your deployed Render backend (set after Render deployment)
VITE_API_BASE_URL=https://goumandira-backend.onrender.com
